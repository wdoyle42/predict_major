data/raw/
data/processed/

# Large model objects - reproducible from pipeline
outputs/models/

# OS artifacts
.DS_Store
Thumbs.db

# Rendered paper outputs (optional: remove if you want to commit PDFs)
paper/*.pdf
paper/*.html
paper/paper_files/

# Temporary files
*.tmp
*.log
.Rproj.user
